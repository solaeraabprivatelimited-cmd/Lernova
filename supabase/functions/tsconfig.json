{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "npm:nodemailer": [
        "../../node_modules/@types/nodemailer/index.d.ts"
      ]
    }
  },
  "include": [
    "./**/*.ts"
  ]
}
