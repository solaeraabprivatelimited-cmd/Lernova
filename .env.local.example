# ✅ .env.local EXAMPLE FOR LOCAL DEVELOPMENT
# Use this as a template to create your own .env.local file
# YOUR .env.local SHOULD NEVER BE COMMITTED TO GIT!
#
# HOW TO USE:
# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in your actual credentials from Supabase dashboard
# 3. Run: git rm --cached .env.local (if accidentally tracked)
# 4. Verify: grep ".env.local" .gitignore

# ─────────────────────────────────────────────────────────────
# SUPABASE CREDENTIALS
# ─────────────────────────────────────────────────────────────

# Your local Supabase URL (from Supabase dashboard > settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous key (from Supabase dashboard > settings > API)
# This is safe to expose in the browser - it only has limited permissions
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE5MjAwMDAwMDB9.XXXXX

# Your Supabase service role key (from Supabase dashboard > settings > API)
# ⚠️  CRITICAL: Keep this SECRET - only for backend/Deno functions
# ⚠️  NEVER expose this in client code or browser
# ⚠️  NEVER commit this to version control
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJzZXJ2aWNlX3JvbGUiLCJpYXQiOjE2MDAwMDAwMDAsImV4cCI6MTkyMDAwMDAwMH0.XXXXX

# ─────────────────────────────────────────────────────────────
# AI MENTOR - GROQ CONFIGURATION
# ─────────────────────────────────────────────────────────────

# Groq API Key (from https://console.groq.com/keys)
# This enables the AI Mentor feature with fast, unlimited inference
# Get your free API key: https://console.groq.com
# Safe to expose in browser (Groq enforces rate limits per account)
VITE_GROQ_API_KEY=your-groq-api-key-here

# ─────────────────────────────────────────────────────────────
# DEVELOPMENT-ONLY SETTINGS
# ─────────────────────────────────────────────────────────────

# Allow localhost for development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# Enable debug mode for development
DEBUG_MODE=true
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────
# HOW TO GET YOUR CREDENTIALS
# ─────────────────────────────────────────────────────────────
#
# SUPABASE:
# 1. Go to: https://app.supabase.com/
# 2. Select your project
# 3. Click: Settings (gear icon) > API
# 4. Copy the credentials
#
# GROQ API KEY:
# 1. Go to: https://console.groq.com
# 2. Sign up (free account with unlimited API calls)
# 3. Click: "Keys" in sidebar
# 4. Click: "Create API Key"
# 5. Copy and paste the key here
#
# ✅ SAFETY CHECKLIST:
# ✓ You have .env.local listed in .gitignore (checked ✅)
# ✓ You will NOT commit .env.local to git
# ✓ You will run: git rm --cached .env.local (if added before)
# ✓ You keep service role key private
# ✓ You rotate keys regularly
